# RLS Logistics — Environment Configuration
# =========================================

# 1. Memory Layer (Pinecone Vector DB)
PINECONE_API_KEY=your-api-key-here
PINECONE_INDEX=rls-logistics-hubs

# 2. Telemetry Layer (TimescaleDB)
# Format: postgresql://user:pass@host:port/dbname
TIMESCALE_DSN=postgresql://rls_user:rls_pass@localhost:5432/rls_logistics

# 3. Micro-service Networking (Docker defaults)
ROUTING_ENGINE_URL=http://localhost:3000
GNN_SIDECAR_URL=http://localhost:8000

# 4. Logger Level
RUST_LOG=routing_engine=info
PYTHONUNBUFFERED=1
